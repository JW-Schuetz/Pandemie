\begin_layout Subsubsection*
Impfstatistik
\end_layout

\begin_layout Standard
Datum der 2.
 Impfung des letzten Bürgers 
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Es wird ein linearer Zusammenhang angenommen zwischen der Zeit 
\begin_inset Formula $t$
\end_inset

 und Anzahl der Impfungen 
\begin_inset Formula $n$
\end_inset


\begin_inset Formula 
\begin{eqnarray*}
n & = & \alpha t+\beta.
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Plain Layout
Zum Impfstartzeitpunkt 
\begin_inset Formula $t_{0}$
\end_inset

 galt 
\begin_inset Formula $n=0$
\end_inset

 daraus folgt 
\begin_inset Formula 
\begin{eqnarray*}
0 & = & \alpha t_{0}+\beta\\
\beta & = & -\alpha t_{0}.
\end{eqnarray*}

\end_inset

 Zum aktuellen Zeitpunkt 
\begin_inset Formula $t_{a}$
\end_inset

 seien 
\begin_inset Formula $N$
\end_inset

 Impfungen verabreicht worden
\begin_inset Formula 
\begin{eqnarray*}
N & = & \alpha t_{a}+\beta\\
 & = & \alpha t_{a}-\alpha t_{0}\\
\alpha & = & \frac{N}{t_{a}-t_{0}}.
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Plain Layout
Insgesamt folgt
\begin_inset Formula 
\begin{eqnarray*}
n & = & \alpha t+\beta\\
 & = & \alpha\left(t-t_{0}\right)\\
 & = & N\frac{t-t_{0}}{t_{a}-t_{0}}.
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Plain Layout
Die Frage ist, zu welchem Zeitpunkt 
\begin_inset Formula $t_{e}$
\end_inset

 jeder der 
\begin_inset Formula $N_{e}$
\end_inset

 Einwohner 2 Impfungen bekommen hat
\begin_inset Formula 
\begin{eqnarray*}
2N_{e} & = & N\frac{t-t_{0}}{t_{a}-t_{0}}\\
\frac{2N_{e}}{N}\left(t_{a}-t_{0}\right) & = & t-t_{0}\\
t & = & \frac{2N_{e}}{N}\left(t_{a}-t_{0}\right)+t_{0}.
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Plain Layout
Dreisatz: 1 Mio in 18 Tagen, wann 160 Mio ? In 160 * 18 = 2880 Tagen, also
 in 7.89 Jahren.-
